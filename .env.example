# ============================================================
# Environment Variables — DA Admin
# ============================================================
# Copy this file to .env and fill in your values.
# Get these from: Supabase Dashboard > Project Settings > API
#
# IMPORTANT: Never commit your .env file to version control.
# ============================================================

# ── Frontend (Vite / browser-side) ──────────────────────────
# Public URL of your Supabase project
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Public anonymous key — safe to expose in the browser
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Netlify Functions (server-side only) ────────────────────
# Set these in: Netlify Dashboard > Site > Environment variables
# DO NOT put secret keys in this file or commit them to git.
#
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
